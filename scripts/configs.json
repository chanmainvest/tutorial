{
  "_comment": "LLM + translation configuration for scripts/translate-batch.py. Set 'provider' to anthropic | openai | gemini and the script reads the matching block under 'providers'. CLI flags (--provider, --model, --locale, --file, --force, --dry-run) override these defaults.",

  "provider": "anthropic",
  "locales": ["hk", "tw", "cn"],
  "source_dir": "course",
  "output_dir": null,
  "file_pattern": null,
  "force": false,
  "dry_run": false,
  "skip_youtube_section": false,

  "providers": {
    "anthropic": {
      "model": "claude-sonnet-4-6-20250514",
      "max_tokens": 65536,
      "thinking_budget_tokens": 8000,
      "thinking_effort": "medium",
      "api_key_env": "ANTHROPIC_API_KEY",
      "input_cost_per_mtok": 3.0,
      "output_cost_per_mtok": 15.0
    },
    "openai": {
      "model": "gpt-5.4-mini",
      "max_output_tokens": 65536,
      "thinking_effort": "medium",
      "api_key_env": "OPENAI_API_KEY",
      "input_cost_per_mtok": 0.25,
      "output_cost_per_mtok": 2.0
    },
    "gemini": {
      "model": "gemini-3.1-flash",
      "max_output_tokens": 65536,
      "thinking_budget_tokens": 8000,
      "thinking_effort": "medium",
      "api_key_env": "GEMINI_API_KEY",
      "input_cost_per_mtok": 0.15,
      "output_cost_per_mtok": 0.6
    }
  }
}
